# Copy to `functions/.env` (gitignored). Do not commit real values.
#
# How vars reach your code:
# 1) This file on disk — `src/init-env.ts` loads `.env` then `.env.local` on cold start.
# 2) Emulator — `firebase emulators:start` also merges `functions/.env` (and `.env.local`).
# 3) Production — from the machine that has `functions/.env`, run:
#      firebase deploy --only functions
#    The CLI prints "Loaded environment variables from .env" and sets them on Cloud Functions.
#    The `.env` file itself is not uploaded; only the values are applied in Google Cloud.
#
# Stripe → Secret key (sk_test_...), Webhook signing secret (whsec_...), each Price ID (price_...)

STRIPE_MODE=test
STRIPE_SECRET_KEY_TEST=
STRIPE_WEBHOOK_SECRET_TEST=

# Fallbacks (optional if _TEST vars are set)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

APP_URL=http://localhost:5173

# Customer portal — optional. Stripe Dashboard → Settings → Billing → Customer portal → copy "Configuration" ID (bpc_...).
# When set, createCustomerPortalSession uses this config (retention offers, cancellation flow, allowed plan switches).
# STRIPE_MODE=test uses *_TEST; live uses *_LIVE. STRIPE_BILLING_PORTAL_CONFIGURATION_ID applies to both if mode-specific unset.
# STRIPE_BILLING_PORTAL_CONFIGURATION_ID_TEST=bpc_...
# STRIPE_BILLING_PORTAL_CONFIGURATION_ID_LIVE=bpc_...
# STRIPE_BILLING_PORTAL_CONFIGURATION_ID=
#
# Optional: separate portal configs so solo orgs only see solo prices and gym only gym (copy each bpc_ from Dashboard).
# STRIPE_BILLING_PORTAL_CONFIGURATION_ID_SOLO_TEST=bpc_...
# STRIPE_BILLING_PORTAL_CONFIGURATION_ID_SOLO_LIVE=bpc_...
# STRIPE_BILLING_PORTAL_CONFIGURATION_ID_GYM_TEST=bpc_...
# STRIPE_BILLING_PORTAL_CONFIGURATION_ID_GYM_LIVE=bpc_...
#
# In EACH portal config → Subscriptions → add every Price customers may switch to. Missing prices = missing options in “Update subscription”.
# Or use Stripe CLI / Stripe Shell: `stripe billing_portal configurations update bpc_...` with -d features[subscription_update][products][…] (see scripts/stripe-portal-attach-catalog-test.sh).
# Stripe allows at most 10 products per portal config for plan switches — use SOLO + GYM configs (11 tiers = 6 + 5).
#
# Stripe Customer Portal rule: you cannot add two Prices on the SAME Product if they share the same billing interval + currency (e.g. two “monthly GBP” on “One Assess Solo Coach”). The portal shows an error like “same billing period and currency as another pricing plan for the same product.”
# Fix: use ONE Stripe Product per capacity tier (e.g. “Solo · 10 clients” with only monthly + annual prices; repeat for S20, S35, …). Gym: one product per G50–G250. Your app only cares about Price IDs in the STRIPE_PACKAGE_* vars below, not how products are grouped.
#
# Portal shows only payment method + empty invoices (no upgrade/downgrade/cancel)?
# 1) Stripe Dashboard → Settings → Billing → Customer portal → edit the configuration (same as bpc_ above if set).
#    Turn on subscription management and add every subscription Price customers may switch to.
# 2) The Customer needs a Subscription in Stripe (saved card alone is not enough). Complete Checkout or fix webhooks.

# Logged-out landing → createLandingGuestCheckoutSession. Only for local/staging E2E.
# Launch: set to false (or remove) so anonymous users cannot open Checkout from marketing.
# Server also requires STRIPE_MODE=test for this callable — not used in live billing mode.
# Must be exactly: true when enabled
ENABLE_LANDING_GUEST_CHECKOUT=true

# Solo S10–S100 + Gym G50–G250 (paste each price_... from Stripe Test mode)
STRIPE_PACKAGE_S10_MONTHLY_TEST=
STRIPE_PACKAGE_S10_ANNUAL_TEST=
STRIPE_PACKAGE_S20_MONTHLY_TEST=
STRIPE_PACKAGE_S20_ANNUAL_TEST=
STRIPE_PACKAGE_S35_MONTHLY_TEST=
STRIPE_PACKAGE_S35_ANNUAL_TEST=
STRIPE_PACKAGE_S50_MONTHLY_TEST=
STRIPE_PACKAGE_S50_ANNUAL_TEST=
STRIPE_PACKAGE_S75_MONTHLY_TEST=
STRIPE_PACKAGE_S75_ANNUAL_TEST=
STRIPE_PACKAGE_S100_MONTHLY_TEST=
STRIPE_PACKAGE_S100_ANNUAL_TEST=
STRIPE_PACKAGE_G50_MONTHLY_TEST=
STRIPE_PACKAGE_G50_ANNUAL_TEST=
STRIPE_PACKAGE_G100_MONTHLY_TEST=
STRIPE_PACKAGE_G100_ANNUAL_TEST=
STRIPE_PACKAGE_G150_MONTHLY_TEST=
STRIPE_PACKAGE_G150_ANNUAL_TEST=
STRIPE_PACKAGE_G200_MONTHLY_TEST=
STRIPE_PACKAGE_G200_ANNUAL_TEST=
STRIPE_PACKAGE_G250_MONTHLY_TEST=
STRIPE_PACKAGE_G250_ANNUAL_TEST=

STRIPE_CUSTOM_BRANDING_TEST=

# ---------------------------------------------------------------------------
# APEX OS — product analytics ingest (optional)
# Same secret as Vercel PRODUCT_ANALYTICS_INGEST_SECRET on apex-os.
# After adding to functions/.env, deploy: firebase deploy --only functions
# ---------------------------------------------------------------------------
APEX_PRODUCT_ANALYTICS_SECRET=
APEX_PRODUCT_ANALYTICS_URL=https://os.one-assess.com/api/product-analytics-ingest

# ---------------------------------------------------------------------------
# Slack — billing event alerts (optional)
# Posts to this webhook on:
#   - New subscription, trial started, cancellation, payment failed, trial ending
#   - past_due subscription
#   - Capacity warning (80%) and capacity full
#   - MRR drop > threshold
#   - AI cost spike > threshold
# Create an Incoming Webhook in your Slack workspace and paste the URL here.
# ---------------------------------------------------------------------------
SLACK_BILLING_WEBHOOK_URL=

# Alert thresholds (optional — defaults shown)
# ALERT_MRR_DROP_PCT=20          # Alert when MRR drops more than this % in one day
# ALERT_AI_COST_SPIKE_GBP=50     # Alert when MTD AI spend first crosses this amount (GBP)
