# Copy to `.env` in this folder (same directory as package.json):
#   cp env.example .env
# Then set RESEND_API_KEY from Resend → Settings → API Keys.

RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM=noreply@one-assess.com
PUBLIC_APP_HOST=https://app.one-assess.com

# Public remote check-in (lifestyle and optional posture photos). Set to true after deploy, then redeploy functions.
# Firebase Console: same value under Functions runtime config / secrets for your project.
# Deploy remote callables:
#   npm run deploy:remote-mvp
# Or: firebase deploy --only functions:createRemoteAssessmentToken,functions:getRemoteAssessmentSession,functions:submitRemoteAssessmentFields,functions:getRemotePostureUploadUrl
#
# Manual E2E after deploy:
#   1) Create client under org; open assessment wizard → Send link first → pick scope → Generate link.
#   2) Incognito: open /remote/{token}; submit (and upload photos if scope includes posture).
#   3) Firestore: organizations/{orgId}/clients/{slug} → formData updated; remoteIntakeAwaitingStudio true.
# REMOTE_ASSESSMENT_MVP=false

# Optional: personal onboarding welcome from you (verified sender in Resend). Unset = short product welcome from RESEND_FROM.
# FOUNDER_WELCOME_FROM=Your Name <you@your-domain.com>
# FOUNDER_SIGN_OFF_NAME=Your Name
# FOUNDER_FEEDBACK_EMAIL=you@your-domain.com

# Optional: absolute URL to a PNG/SVG logo for transactional email headers (see docs/TRANSACTIONAL_EMAILS.md).
# EMAIL_ASSETS_LOGO_URL=https://app.one-assess.com/your-email-logo.png
