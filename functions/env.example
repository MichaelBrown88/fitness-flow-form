# Copy to `.env` in this folder (same directory as package.json):
#   cp env.example .env
# Then set RESEND_API_KEY from Resend → Settings → API Keys.

RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM=noreply@one-assess.com
PUBLIC_APP_HOST=https://app.one-assess.com

# Optional: personal onboarding welcome from you (verified sender in Resend). Unset = short product welcome from RESEND_FROM.
# FOUNDER_WELCOME_FROM=Your Name <you@your-domain.com>
# FOUNDER_SIGN_OFF_NAME=Your Name
# FOUNDER_FEEDBACK_EMAIL=you@your-domain.com

# Optional: absolute URL to a PNG/SVG logo for transactional email headers (see docs/TRANSACTIONAL_EMAILS.md).
# EMAIL_ASSETS_LOGO_URL=https://app.one-assess.com/your-email-logo.png
