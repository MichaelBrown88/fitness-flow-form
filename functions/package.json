{
  "name": "fitness-flow-functions",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf lib",
    "deploy": "npm run build && firebase deploy --only functions",
    "deploy:remote-mvp": "npm run build && firebase deploy --only functions:createRemoteAssessmentToken,functions:getRemoteAssessmentSession,functions:submitRemoteAssessmentFields,functions:getRemotePostureUploadUrl",
    "lint": "eslint \"src/**/*.{ts,js}\"",
    "stripe:catalog": "npx ts-node --transpile-only src/scripts/createStripeCatalog.ts",
    "email:preview": "npx ts-node --transpile-only src/scripts/sendEmailPreview.ts",
    "serve": "npm run build && firebase emulators:start --only functions",
    "start": "ts-node -r tsconfig-paths/register src/index.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@resvg/resvg-js": "^2.6.2",
    "dotenv": "^16.4.7",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "resend": "^6.11.0",
    "stripe": "^20.3.1"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "rimraf": "^6.1.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
