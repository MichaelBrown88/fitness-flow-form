{
  "name": "fitness-flow-functions",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf lib",
    "deploy": "npm run build && firebase deploy --only functions",
    "lint": "eslint \"src/**/*.{ts,js}\"",
    "stripe:catalog": "npx ts-node --transpile-only src/scripts/createStripeCatalog.ts",
    "serve": "npm run build && firebase emulators:start --only functions",
    "start": "ts-node -r tsconfig-paths/register src/index.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "resend": "^6.9.4",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^7.2.2",
    "stripe": "^20.3.1"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "rimraf": "^6.1.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
