# Quick script to load nvm in current terminal
# Run: source .zshrc-load-nvm

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

echo "✅ nvm loaded! Node.js $(node --version) and npm $(npm --version) are now available."

