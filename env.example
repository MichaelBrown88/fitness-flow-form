# SECURITY: Copy this file to .env and fill in your Firebase config values
# NEVER commit the .env file to version control
# Vite only exposes variables prefixed with VITE_

# Firebase Configuration
# Get these values from your Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# If custom org logos fail in the browser with CORS / Workbox "no-response" on firebasestorage.googleapis.com,
# apply Storage CORS once (bucket name must match Console → Storage, often project.firebasestorage.app):
#   npm run storage:cors:set
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Optional: Public app URL (for emails, Stripe redirects). Defaults to build origin.
# Used by Cloud Functions for transactional emails and invite links. Set in Firebase too:
#   firebase functions:config:set app.public_app_host="https://your-app.web.app"
# VITE_PUBLIC_APP_HOST=https://your-app.web.app

# Optional: Stripe publishable key. If unset, onboarding uses free trial only; no checkout.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# --- Landing guest checkout (logged-out “buy from pricing”) ---
# Launch intent: marketing pricing is informational; signup → onboarding → paywalls (solo 3rd client, gym trial end).
# Keep guest checkout OFF in production builds; use it only for fast Stripe E2E on preview/staging/local.
#
# Production hosting build: omit both lines below (or set DISABLE) so paid cards on the landing do not open Checkout.
# Local / preview channel: set ENABLE=true to test Stripe without an account (requires functions: ENABLE_LANDING_GUEST_CHECKOUT=true + STRIPE_MODE=test).
# VITE_ENABLE_LANDING_GUEST_CHECKOUT=true
# VITE_DISABLE_LANDING_GUEST_CHECKOUT=true

# Optional: reCAPTCHA v3 site key for Firebase App Check.
# Register a site at https://www.google.com/recaptcha/admin and enable App Check
# in Firebase Console > Build > App Check. When set, App Check tokens are attached
# to all Cloud Function calls, protecting them from abuse.
# VITE_RECAPTCHA_SITE_KEY=6Lc...

# Optional: Set to "true" to enable App Check debug mode in development.
# Firebase will print a debug token to the console; add it to the App Check
# "Debug tokens" list in the Firebase Console to allow local testing.
# VITE_APP_CHECK_DEBUG=true

# Instructions:
# 1. Copy this file: cp env.example .env
# 2. Replace all placeholder values with your actual Firebase configuration
# 3. Verify .env is in .gitignore (it should be by default)
# 4. Never share or commit your .env file

# --- Gemini Live (posture QR companion / guided capture) ---
# If Live fails with setupComplete / model not found, use a model ID your Firebase/Vertex project has enabled.
# VITE_GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio
# When 3.1 Flash Live is enabled for the project:
# VITE_GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# Optional (3.1 latency): VITE_GEMINI_LIVE_THINKING_LEVEL=minimal

