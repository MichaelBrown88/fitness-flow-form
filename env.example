# SECURITY: Copy this file to .env and fill in your Firebase config values
# NEVER commit the .env file to version control
# Vite only exposes variables prefixed with VITE_

# Firebase Configuration
# Get these values from your Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Instructions:
# 1. Copy this file: cp env.example .env
# 2. Replace all placeholder values with your actual Firebase configuration
# 3. Verify .env is in .gitignore (it should be by default)
# 4. Never share or commit your .env file

