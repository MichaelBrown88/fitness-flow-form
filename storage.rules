rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Posture photos for live sessions
    match /sessions/{sessionId}/{fileName} {
      allow read, write: if true; // Linked to sessionId for security
    }
    
    // Default: allow read if authenticated
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}









