rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ============================================================
    // Multi-tenant isolation (Firestore-backed)
    // ============================================================
    // Impersonation uses client-side effectiveOrgId only; JWT is unchanged.
    // Platform admins are not in every org's coaches map, so isPlatformAdmin()
    // allows support/impersonation to access org assets when needed.

    function isAuthenticated() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return isAuthenticated() &&
        firestore.exists(/databases/(default)/documents/platform_admins/$(request.auth.uid));
    }

    function isOrgCoach(orgId) {
      return isAuthenticated() &&
        firestore.exists(
          /databases/(default)/documents/organizations/$(orgId)/coaches/$(request.auth.uid)
        );
    }

    function canAccessOrgStorage(orgId) {
      return isOrgCoach(orgId) || isPlatformAdmin();
    }

    // Organization-specific data (logos, client images, posture scans, etc.)
    // Path structure: organizations/{orgId}/**
    match /organizations/{orgId}/{allPaths=**} {
      allow read: if canAccessOrgStorage(orgId);
      allow write: if canAccessOrgStorage(orgId);
    }

    // Reserved for future companion uploads. App currently uses
    // organizations/{orgId}/clients/... only (see backgroundUpload.ts).
    match /live_sessions/{sessionId}/{allPaths=**} {
      allow read, write: if false;
    }

    // Public report share images: path includes unguessable share token (same secret as /r/:token).
    // Writes only via Admin SDK (Functions); clients and crawlers read for OG / downloads.
    match /publicReportShare/{token}/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // No catch-all rule = everything else is DENIED by default
  }
}
