              stats.scoreChange > 0 ? 'text-emerald-600' : stats.scoreChange < 0 ? 'text-rose-600' : 'text-slate-900'
            }`}>
              {stats.scoreChange > 0 ? '+' : ''}{stats.scoreChange}
            </div>
