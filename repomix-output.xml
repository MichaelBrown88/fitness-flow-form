                            size="sm"
                            className="flex-1 bg-slate-900 text-white hover:bg-slate-800"
                          >
                            <UserPlus className="h-3 w-3 mr-1" />
                            New Assessment
                            <ChevronDown className="h-3 w-3 ml-1" />
