rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Coaches can read/write their own assessments
    match /coaches/{coachId}/assessments/{assessmentId} {
      allow read, write: if request.auth != null && request.auth.uid == coachId;
    }
    
    // Live Sessions for Companion Camera
    // IMPORTANT: Allowing public access for dev testing
    match /live_sessions/{sessionId} {
      allow read, write: if true;
    }
    
    // Allow coaches to list their assessments (for dashboard)
    match /coaches/{coachId} {
      allow read: if request.auth != null && request.auth.uid == coachId;
    }

    // Public reports
    match /publicReports/{publicId} {
      allow read: if resource.data.visibility == 'public' || 
                     (request.auth != null && resource.data.coachUid == request.auth.uid);
      allow create, update: if request.auth != null && request.resource.data.coachUid == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
