rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // allow all authenticated users to read/write their own coach data
    match /coaches/{coachId} {
      allow read, write: if request.auth != null && request.auth.uid == coachId;
      
      // Explicitly allow subcollections
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == coachId;
      }
    }
    
    // Live Sessions: Used by Companion Camera (unauthenticated or token-based)
    match /live_sessions/{sessionId} {
      allow read, write: if true;
    }
    
    // Public reports: Shared with clients
    match /publicReports/{reportId} {
      allow read: if resource == null || 
                     resource.data.visibility == 'public' || 
                     (request.auth != null && resource.data.coachUid == request.auth.uid);
                     
      allow create, update: if request.auth != null;
    }

    // Root level assessments (for legacy or direct access)
    match /assessments/{assessmentId} {
      allow read, write: if request.auth != null;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
