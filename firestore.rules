rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow any authenticated user to read/write all documents during SaaS migration
    // We will tighten this once the foundation is verified.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Platform Admin Setup - Allow initial seeding (temporary, tighten after setup)
    // These rules allow the one-time platform admin initialization
    match /platform_admins/{adminId} {
      allow read: if true;
      allow write: if true; // Temporary: Allow initial setup
    }
    
    match /platform_admin_lookup/{lookupId} {
      allow read: if true;
      allow write: if true; // Temporary: Allow initial setup
    }

    // Public reports: Shared with clients (No auth required for viewing)
    match /publicReports/{reportId} {
      allow read: if true; 
    }
    
    // Live Sessions: Used by Companion Camera (No auth required for updates)
    match /live_sessions/{sessionId} {
      allow read, update: if true;
    }
  }
}
