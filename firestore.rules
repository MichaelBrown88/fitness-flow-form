rules_version = '2';

// ⚠️  DEPLOYMENT COUPLING — READ BEFORE DEPLOYING
// These rules are tightly coupled to the app code changes introduced in Phase 3.
//
// Phase 3 (data minimization) tightened clients/* and subcollection reads so that
// coaches only see their own clients (resource.data.coachUid == request.auth.uid).
// The app code mirrors this via the coachUid filter in listClientSchedules() and
// the coachUidFilter param in useAssessmentList.
//
// ALWAYS deploy rules + app code together in a single `firebase deploy`.
//   • Rules deploy BEFORE app code  → coaches get permission-denied on their own data
//   • App code deploys BEFORE rules → data minimization is not enforced at DB level
//
// deploy-preview.sh is HOSTING ONLY — it does NOT update these rules.
// Use `firebase deploy` (full deploy) any time firestore.rules has pending changes.

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // HELPER FUNCTIONS
    // =========================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    // Custom claim set via Admin SDK (optional; speeds up access before platform_admins/{uid} exists)
    function isPlatformAdminToken() {
      return request.auth != null &&
        request.auth.token.platformAdmin == true;
    }

    function isPlatformAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/platform_admins/$(request.auth.uid)) ||
          isPlatformAdminToken());
    }

    // First-time bootstrap: lookup row lists this auth uid, or pending_* before migration
    function platformAdminLookupForAuth() {
      return get(/databases/$(database)/documents/platform_admin_lookup/$(request.auth.token.email));
    }

    function canBootstrapPlatformAdminDoc(adminId) {
      return isAuthenticated() &&
        request.auth.uid == adminId &&
        request.auth.token.email is string &&
        request.auth.token.email.size() > 0 &&
        exists(/databases/$(database)/documents/platform_admin_lookup/$(request.auth.token.email)) &&
        (platformAdminLookupForAuth().data.uid == adminId ||
          platformAdminLookupForAuth().data.uid.matches('pending_.+'));
    }

    // Platform admin is not currently impersonating an org (blocks writes during impersonation)
    function isNotImpersonating() {
      return !exists(/databases/$(database)/documents/platform/active_impersonations/sessions/$(request.auth.uid));
    }

    // Zero-friction /try flow: org id is `{uid}_sandbox` (see SandboxTrial.tsx)
    function ownsSandboxOrgId(orgId) {
      return isAuthenticated() && orgId == request.auth.uid + '_sandbox';
    }

    function sandboxOrgPayloadValid() {
      let d = request.resource.data;
      return d.get('metadata', {}).get('isSandbox', false) == true &&
        d.get('subscription', {}).get('plan', '') == 'sandbox';
    }

    // Coach belongs to the given org (checked against the coaches subcollection)
    function isOrgCoach(orgId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/organizations/$(orgId)/coaches/$(request.auth.uid));
    }

    // Coach has admin or owner role in the given org (org_admin matches app userProfiles.role)
    function isOrgAdmin(orgId) {
      return isOrgCoach(orgId) &&
        get(/databases/$(database)/documents/organizations/$(orgId)/coaches/$(request.auth.uid)).data.role in ['owner', 'admin', 'org_admin'];
    }

    // Platform admin has data access to org (owner's org is always comped)
    function hasDataAccess(orgId) {
      let orgData = get(/databases/$(database)/documents/organizations/$(orgId)).data;
      return (orgData.get('subscription', {}).get('isComped', false) == true) ||
             (orgData.get('dataAccessPermission', {}).get('platformAdminAccess', false) == true);
    }

    // Org coach or platform admin with data access
    function canReadOrgData(orgId) {
      return isOrgCoach(orgId) || (isPlatformAdmin() && hasDataAccess(orgId));
    }

    function canWriteOrgData(orgId) {
      return isOrgCoach(orgId) ||
        (isPlatformAdmin() && hasDataAccess(orgId) && isNotImpersonating());
    }

    // True when the authenticated coach is the assigned coach for the given client.
    // Used in client-doc and subcollection rules to enforce data minimisation:
    // coaches may only read their own clients' records.
    function isClientCoach(orgId, clientSlug) {
      return isOrgCoach(orgId) &&
        get(/databases/$(database)/documents/organizations/$(orgId)/clients/$(clientSlug)).data.coachUid == request.auth.uid;
    }

    // Readable by: org admin, the assigned coach, or a platform admin with data access.
    function canReadClientDoc(orgId, clientSlug) {
      return isOrgAdmin(orgId) ||
             isClientCoach(orgId, clientSlug) ||
             (isPlatformAdmin() && hasDataAccess(orgId));
    }

    // Max active (non-archived) clients for billing - subscription.clientCap, legacy clientSeats, or free tier 2
    function effectiveClientCap(orgId) {
      let org = get(/databases/$(database)/documents/organizations/$(orgId)).data;
      let sub = org.get('subscription', {});
      let cap = sub.get('clientCap', null);
      let seats = sub.get('clientSeats', null);
      return cap != null ? int(cap) : (seats != null ? int(seats) : 2);
    }

    // Denormalized active client count (maintained by Cloud Function aggregation)
    function statsClientCount(orgId) {
      let org = get(/databases/$(database)/documents/organizations/$(orgId)).data;
      let stats = org.get('stats', {});
      return int(stats.get('clientCount', 0));
    }

    // Owning coach UID on a public report doc (for subcollection writes).
    function publicReportCoachUid(token) {
      return get(/databases/$(database)/documents/publicReports/$(token)).data.coachUid;
    }

    // AI usage log create — coaches append-only for their own UID and org (no update/delete from client)
    function aiUsageLogCreateKeysValid() {
      return request.resource.data.keys().hasOnly([
        'timestamp', 'type', 'status', 'provider', 'coachUid',
        'organizationId', 'costEstimate', 'costFils', 'tokensUsed', 'metadata'
      ]);
    }

    function aiUsageLogCreateAllowed() {
      let d = request.resource.data;
      return aiUsageLogCreateKeysValid() &&
        isAuthenticated() &&
        isNotImpersonating() &&
        d.coachUid == request.auth.uid &&
        d.organizationId is string &&
        d.organizationId.size() > 0 &&
        isOrgCoach(d.organizationId) &&
        d.type in ['ocr_inbody', 'posture_analysis', 'exercise_recommendation', 'comparison_narrative', 'coach_assistant_response'] &&
        d.status in ['local_success', 'ai_fallback', 'ai_success', 'error'] &&
        d.provider in ['local', 'gemini', 'mediapipe', 'pattern'] &&
        d.costEstimate is number &&
        d.costFils is number &&
        d.tokensUsed is number &&
        d.metadata is map &&
        d.timestamp == request.time;
    }

    // =========================================================
    // ORGANIZATIONS
    // =========================================================

    match /organizations/{orgId} {
      allow read: if isPlatformAdmin() || isOrgCoach(orgId) || ownsSandboxOrgId(orgId);
      allow create, update: if isPlatformAdmin() || isOrgAdmin(orgId) ||
        (ownsSandboxOrgId(orgId) && sandboxOrgPayloadValid());
      allow delete: if isPlatformAdmin() || isOrgAdmin(orgId);

      // Coaches
      match /coaches/{coachId} {
        allow read: if canReadOrgData(orgId);
        allow write: if isOrgAdmin(orgId) ||
          (isPlatformAdmin() && hasDataAccess(orgId) && isNotImpersonating());
        // First row (bootstrap): profile.organizationId must match this org (invite roster is server-written).
        allow create: if isAuthenticated() && request.auth.uid == coachId &&
          exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.organizationId == orgId;
        // Coaches may update only their own roster row: displayName + email, no privilege escalation
        allow update: if isAuthenticated() && request.auth.uid == coachId &&
          exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.organizationId == orgId &&
          request.resource.data.uid == request.auth.uid &&
          (!resource.data.keys().hasAny(['uid']) || resource.data.uid == request.auth.uid) &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'email']);
      }

      // Clients + all subcollections (current, sessions, roadmap, achievements, drafts)
      // Data minimisation: regular coaches may only read/write their assigned clients.
      // Org admins and platform admins with data access retain full visibility.
      match /clients/{clientSlug} {
        // list: Firestore enforces this when coaches query with where('coachUid','==',uid).
        // get:  direct single-doc fetch requires the coach to be the assigned coach.
        allow read: if isOrgAdmin(orgId) ||
                       (isOrgCoach(orgId) && resource.data.coachUid == request.auth.uid) ||
                       (isPlatformAdmin() && hasDataAccess(orgId));
        allow create: if canWriteOrgData(orgId) && (
            (isPlatformAdmin() && hasDataAccess(orgId) && isNotImpersonating()) ||
            statsClientCount(orgId) < effectiveClientCap(orgId)
          );
        allow update, delete: if canWriteOrgData(orgId);

        // Live composite state — source of truth for current client data
        match /current/{doc} {
          allow read: if canReadClientDoc(orgId, clientSlug);
          allow write: if canWriteOrgData(orgId);
        }

        // Assessment event log — append-only, immutable after write
        match /sessions/{sessionId} {
          allow read: if canReadClientDoc(orgId, clientSlug);
          // Only allow create (no update/delete — sessions are immutable)
          allow create: if canWriteOrgData(orgId);
          allow update, delete: if isPlatformAdmin();
        }

        // Roadmap — phases and metric thresholds
        match /roadmap/{doc} {
          allow read: if canReadClientDoc(orgId, clientSlug);
          allow write: if canWriteOrgData(orgId);
        }

        // Achievements — milestones, status badges, streaks
        match /achievements/{doc} {
          allow read: if canReadClientDoc(orgId, clientSlug);
          allow write: if canWriteOrgData(orgId);
        }

        // Assessment drafts — save-for-later
        match /assessmentDrafts/{doc} {
          allow read: if canReadClientDoc(orgId, clientSlug);
          allow write: if canWriteOrgData(orgId);
        }
      }

      // GDPR erasure requests
      match /erasureRequests/{requestId} {
        allow read: if isOrgAdmin(orgId) || (isPlatformAdmin() && hasDataAccess(orgId));
        allow create: if true; // Anyone can submit an erasure request
        allow update: if isOrgAdmin(orgId) || (isPlatformAdmin() && hasDataAccess(orgId));
        allow delete: if false;
      }

      /** Monthly AI assistant usage aggregates (coach tab quotas) */
      match /aiUsage/{monthId} {
        allow read: if canReadOrgData(orgId);
        allow create, update: if canWriteOrgData(orgId);
        allow delete: if false;
      }
    }

    // =========================================================
    // COACH INVITATIONS  (token is the capability; client writes denied)
    // =========================================================

    match /invitations/{token} {
      allow get: if resource.data.status == 'pending' &&
        resource.data.expiresAt is timestamp &&
        resource.data.expiresAt > request.time;
      allow list: if false;
      allow create, update, delete: if false;
    }

    // =========================================================
    // ONBOARDING SESSIONS  (audit / resume — one doc per uid)
    // =========================================================

    match /onboarding_sessions/{sessionUid} {
      allow read: if isAuthenticated() && request.auth.uid == sessionUid;
      // Doc id must match auth uid; userId field prevents cross-user payloads.
      allow create, update: if isAuthenticated() &&
        request.auth.uid == sessionUid &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // =========================================================
    // USER PROFILES  (one per Firebase Auth user — coaches)
    // =========================================================

    match /userProfiles/{uid} {
      allow read: if request.auth.uid == uid ||
        isPlatformAdmin() ||
        (isAuthenticated() &&
          resource.data.organizationId ==
          get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.organizationId);
      // Self-writes restricted to safe fields (no role escalation); platform admins can write anything
      allow write: if isPlatformAdmin();
      allow update: if request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName', 'email', 'photoURL', 'preferences', 'settings',
          'onboardingComplete', 'equipmentList', 'defaultCadence',
          'completedChecklist', 'dismissedChecklist', 'theme'
        ]);
      // Allow initial profile creation (onboarding sets role + organizationId)
      allow create: if request.auth.uid == uid;
    }

    // =========================================================
    // PUBLIC REPORTS  (client PWA credential)
    // shareToken is both the doc ID and the client's credential.
    // The document holds enough data to render the client's current view.
    // =========================================================

    match /publicReports/{token} {
      // Token IS the credential — allow single-doc fetch only.
      // Coaches may query their own reports (coachUid filter required by Firestore rule).
      allow get: if true;
      allow list: if isAuthenticated() && resource.data.coachUid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.coachUid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.coachUid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.coachUid == request.auth.uid;
    }

    // Token-scoped subcollections (snapshots, achievements, notifications, client check-ins)
    match /publicReports/{token}/snapshots/{snapshotId} {
      allow get: if true;
      allow list: if false;
      allow write: if isAuthenticated() && publicReportCoachUid(token) == request.auth.uid;
    }

    match /publicReports/{token}/achievements/{achievementId} {
      allow get: if true;
      allow list: if false;
      allow write: if isAuthenticated() && publicReportCoachUid(token) == request.auth.uid;
    }

    match /publicReports/{token}/notifications/{notificationId} {
      allow get: if true;
      allow list: if false;
      allow create: if isAuthenticated() && publicReportCoachUid(token) == request.auth.uid;
      allow update: if
        (isAuthenticated() && publicReportCoachUid(token) == request.auth.uid) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && publicReportCoachUid(token) == request.auth.uid;
    }

    match /publicReports/{token}/lifestyleCheckins/{checkinId} {
      allow get: if true;
      allow list: if false;
      allow create: if true;
      allow update, delete: if false;
    }

    match /publicReports/{token}/preSessionCheckins/{checkinId} {
      allow get: if true;
      allow list: if false;
      allow create: if true;
      allow update, delete: if false;
    }

    // Client sharing + email consent prefs — token IS the credential.
    // Only a single doc ('prefs') is ever written; clients have no Firebase Auth.
    match /publicReports/{token}/clientConsent/{docId} {
      allow get: if true;
      allow list: if false;
      // Unauthenticated clients may create/update only their own prefs doc.
      // Fields are strictly enumerated to prevent abuse.
      allow create, update: if docId == 'prefs' &&
        request.resource.data.keys().hasOnly([
          'socialSharingConsented', 'monthlyEmailConsented',
          'consentGivenAt', 'consentUpdatedAt'
        ]) &&
        (request.resource.data.socialSharingConsented == null ||
          request.resource.data.socialSharingConsented is bool) &&
        (request.resource.data.monthlyEmailConsented == null ||
          request.resource.data.monthlyEmailConsented is bool);
      allow delete: if false;
    }

    // =========================================================
    // PUBLIC ROADMAPS  (token mirror for client roadmap viewer)
    // Written when coach sets roadmap shareToken; doc ID = that token.
    // =========================================================

    match /publicRoadmaps/{token} {
      allow get: if true;
      // Coaches may query their own roadmaps (coachUid filter required by Firestore rule).
      allow list: if isAuthenticated() && resource.data.coachUid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.coachUid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.coachUid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.coachUid == request.auth.uid;
    }

    // =========================================================
    // LIVE SESSIONS  (real-time posture capture)
    // =========================================================

    match /live_sessions/{sessionId} {
      // Single-doc fetch: sessionId + companionToken are unguessable; companion listens without auth.
      allow get: if true;
      // Org-scoped listing for coach dashboards (matches client queries that filter organizationId).
      allow list: if isAuthenticated() &&
        resource.data.organizationId != null &&
        (isOrgCoach(resource.data.organizationId) ||
          (isPlatformAdmin() && hasDataAccess(resource.data.organizationId)));

      allow create: if isAuthenticated() &&
        request.resource.data.organizationId != null &&
        request.resource.data.clientId != null &&
        isOrgCoach(request.resource.data.organizationId);

      allow update: if isAuthenticated() &&
        resource.data.organizationId != null &&
        isOrgCoach(resource.data.organizationId);

      // Unauthenticated companion (client mobile) may only update capture fields
      allow update: if !isAuthenticated() &&
        exists(/databases/$(database)/documents/live_sessions/$(sessionId)) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'companionJoined', 'lastHeartbeat', 'postureImages',
          'analysis', 'companionLogs',
          'landmarks_front', 'landmarks_back',
          'landmarks_side-left', 'landmarks_side-right'
        ]);
    }

    // =========================================================
    // NOTIFICATIONS  (per-user feed, keyed by Firebase Auth UID)
    // =========================================================

    match /notifications/{uid}/items/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid == uid;
      allow delete: if isAuthenticated() && request.auth.uid == uid;
    }

    // =========================================================
    // PLATFORM ANALYTICS  (Cloud Functions write only)
    // =========================================================

    match /platform_analytics/{doc} {
      allow read: if isPlatformAdmin();
      // Frontend may only clear the "new badge" marker — nothing else
      allow update: if isPlatformAdmin() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenByAdminAt']);
      allow write: if false;
    }

    // =========================================================
    // SYSTEM STATS
    // =========================================================

    match /system_stats/{document} {
      allow read: if isPlatformAdmin();
      allow write: if isPlatformAdmin();
    }

    // =========================================================
    // PLATFORM CONFIG  (feature flags, maintenance mode)
    // Public read so unauthenticated users can see maintenance page.
    // =========================================================

    match /platform/{document} {
      allow read: if true;
      allow write: if isPlatformAdmin();

      match /active_impersonations/sessions/{adminUid} {
        allow read: if isAuthenticated();
        allow write: if isPlatformAdmin() && request.auth.uid == adminUid;
      }
    }

    // =========================================================
    // PLATFORM ADMINS
    // =========================================================

    match /platform_admins/{adminId} {
      allow read: if isAuthenticated();
      allow create, update: if isPlatformAdmin() || canBootstrapPlatformAdminDoc(adminId);
      allow delete: if isPlatformAdmin();
    }

    // Canonical lookup id must equal lowercased auth email (see PLATFORM.admins.lookupKey).
    // get: unauthenticated platform login checks email against lookup; ids are guessable only if email is known.
    match /platform_admin_lookup/{lookupId} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if false;
    }

    // =========================================================
    // PLATFORM AUDIT LOGS
    // =========================================================

    match /platform_audit_logs/{document=**} {
      allow read: if isPlatformAdmin();
      allow write: if isPlatformAdmin();
    }

    // =========================================================
    // AI USAGE LOGS  (root-level)
    // Platform admins can read all logs.
    // Org coaches can read logs for their organisation (organizationId set on doc).
    // Coaches may create append-only logs for self + org (validated). Updates/deletes: Admin SDK / platform only.
    // =========================================================

    match /ai_usage_logs/{logId} {
      allow read: if isPlatformAdmin() ||
        (isAuthenticated() &&
          resource.data.organizationId != null &&
          isOrgCoach(resource.data.organizationId));
      allow create: if aiUsageLogCreateAllowed();
      allow update, delete: if false;
    }

    // =========================================================
    // REMOTE ASSESSMENT TOKENS  (Admin SDK / Cloud Functions only)
    // =========================================================

    match /remoteAssessmentTokens/{tokenId} {
      allow read, write: if false;
    }

    // =========================================================
    // RATE LIMIT COUNTERS  (Cloud Functions only)
    // =========================================================

    match /_rateLimits/{key} {
      allow read, write: if false;
    }
  }
}
