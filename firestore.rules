rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // =========================================================
    // 🛡️ HELPER FUNCTIONS
    // =========================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserProfile() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }
    
    // Check if user is a platform admin (check platform_admins collection)
    function isPlatformAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/platform_admins/$(request.auth.uid));
    }
    
    function isOrgMember(orgId) {
      let profile = getUserProfile();
      return isAuthenticated() && profile.organizationId == orgId;
    }
    
    function isOrgAdmin(orgId) {
      let profile = getUserProfile();
      return isOrgMember(orgId) && profile.role == 'org_admin';
    }
    
    // Check if organization has granted data access permission to platform admin
    // Comped organizations (like One Fitness - owner's company) automatically have access
    function hasDataAccessPermission(orgId) {
      let orgData = get(/databases/$(database)/documents/organizations/$(orgId)).data;
      // Comped organizations get automatic access (owner's company for testing)
      // Check if explicit permission granted
      return (orgData.keys().hasAll(['subscription']) && 
              orgData.subscription.keys().hasAll(['isComped']) && 
              orgData.subscription.isComped == true) || 
             (orgData.keys().hasAll(['dataAccessPermission']) && 
              orgData.dataAccessPermission.keys().hasAll(['platformAdminAccess']) && 
              orgData.dataAccessPermission.platformAdminAccess == true);
    }
    
    // =========================================================
    // 📂 COLLECTION RULES
    // =========================================================
    
    // 1. ORGANIZATIONS
    match /organizations/{orgId} {
      // Platform admin can read org metadata, but NOT sensitive data (assessments, clients) without permission
      // Org members can read their own org
      allow read: if isPlatformAdmin() || isOrgMember(orgId);
      allow write: if isPlatformAdmin() || isOrgAdmin(orgId);
      
      // Subcollections: Coaches, Clients, Assessments - GDPR/HIPAA protected
      match /coaches/{coachId} {
        // Platform admin needs explicit permission OR org is platform owner (One Fitness)
        allow read: if (isPlatformAdmin() && hasDataAccessPermission(orgId)) || 
                    isOrgMember(orgId);
        allow write: if isOrgMember(orgId); // Only org members can write
        
        match /{allChildren=**} {
          allow read: if (isPlatformAdmin() && hasDataAccessPermission(orgId)) || 
                      isOrgMember(orgId);
          allow write: if isOrgMember(orgId);
        }
      }
      
      match /clients/{clientId} {
        allow read: if (isPlatformAdmin() && hasDataAccessPermission(orgId)) || 
                    isOrgMember(orgId);
        allow write: if isOrgMember(orgId);
      }
      
      match /assessments/{assessmentId} {
        allow read: if (isPlatformAdmin() && hasDataAccessPermission(orgId)) || 
                    isOrgMember(orgId);
        allow write: if isOrgMember(orgId);
      }
      
      // Settings and other non-sensitive subcollections
      match /settings/{document=**} {
        allow read: if isPlatformAdmin() || isOrgMember(orgId);
        allow write: if isPlatformAdmin() || isOrgAdmin(orgId);
      }
    }
    
    // 2. USER PROFILES
    match /userProfiles/{userId} {
      allow read: if request.auth.uid == userId 
                  || isPlatformAdmin()
                  || (isAuthenticated() && 
                      get(/databases/$(database)/documents/userProfiles/$(userId)).data.organizationId == 
                      getUserProfile().organizationId);
      
      allow write: if request.auth.uid == userId || isPlatformAdmin();
    }
    
    // 3. COACHES & LEGACY DATA
    match /coaches/{coachId} {
      allow read, write: if request.auth.uid == coachId ||
                         (isAuthenticated() && 
                          get(/databases/$(database)/documents/userProfiles/$(coachId)).data.organizationId == getUserProfile().organizationId &&
                          getUserProfile().role == 'org_admin') ||
                         (isPlatformAdmin() && 
                          get(/databases/$(database)/documents/userProfiles/$(coachId)).data.organizationId != null && 
                          hasDataAccessPermission(get(/databases/$(database)/documents/userProfiles/$(coachId)).data.organizationId));
      
      match /{document=**} {
        allow read, write: if request.auth.uid == coachId ||
                           (isAuthenticated() && 
                            get(/databases/$(database)/documents/userProfiles/$(coachId)).data.organizationId == getUserProfile().organizationId &&
                            getUserProfile().role == 'org_admin') ||
                           (isPlatformAdmin() && 
                            get(/databases/$(database)/documents/userProfiles/$(coachId)).data.organizationId != null && 
                            hasDataAccessPermission(get(/databases/$(database)/documents/userProfiles/$(coachId)).data.organizationId));
      }
    }
    
    // 4. SYSTEM STATS (Platform Admin Only)
    match /system_stats/{document} {
      allow read: if isPlatformAdmin();
      allow write: if false; // Only Cloud Functions (server-side)
    }
    
    // 5. AI USAGE LOGS
    match /ai_usage_logs/{logId} {
      allow read: if isPlatformAdmin() || 
                  (isAuthenticated() && 
                   resource.data.organizationId == getUserProfile().organizationId);
      allow create: if isAuthenticated(); // App creates logs
      allow write: if false; // Only Cloud Functions update costs
    }
    
    // 6. PLATFORM ADMINS (Read-only after setup)
    match /platform_admins/{adminId} {
      allow read: if isAuthenticated(); // Anyone authenticated can check
      allow write: if false; // Only server-side (Cloud Functions)
    }
    
    match /platform_admin_lookup/{lookupId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only server-side
    }
    
    // =========================================================
    // 🔓 PUBLIC ROUTES
    // =========================================================
    
    match /publicReports/{reportId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /live_sessions/{sessionId} {
      // Allow anyone to read sessions (for token validation in companion app)
      // This enables mobile handoff features where clients scan QR codes without authentication
      allow read: if true;
      
      // Allow authenticated users to create sessions
      allow create: if isAuthenticated();
      
      // Allow updates if:
      // 1. User is authenticated (normal flow)
      // 2. OR session exists and is being updated (mobile handoff - token validated client-side)
      // This allows mobile users to upload images via QR code without requiring authentication
      // The companionToken provides security - it's validated client-side before allowing updates
      allow update: if isAuthenticated() || 
                     (resource != null && resource.data.keys().hasAll(['companionToken']));
      
      // Additional permission for platform admins with data access
      allow read: if isPlatformAdmin() && 
                   resource.data.keys().hasAll(['organizationId']) &&
                   resource.data.organizationId != null &&
                   hasDataAccessPermission(resource.data.organizationId);
    }
  }
}
