rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // HELPER FUNCTIONS
    // =========================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/platform_admins/$(request.auth.uid));
    }

    // Platform admin is not currently impersonating an org (blocks writes during impersonation)
    function isNotImpersonating() {
      return !exists(/databases/$(database)/documents/platform/active_impersonations/sessions/$(request.auth.uid));
    }

    // Coach belongs to the given org (checked against the coaches subcollection)
    function isOrgCoach(orgId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/organizations/$(orgId)/coaches/$(request.auth.uid));
    }

    // Coach has admin or owner role in the given org
    function isOrgAdmin(orgId) {
      return isOrgCoach(orgId) &&
        get(/databases/$(database)/documents/organizations/$(orgId)/coaches/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }

    // Platform admin has data access to org (owner's org is always comped)
    function hasDataAccess(orgId) {
      let orgData = get(/databases/$(database)/documents/organizations/$(orgId)).data;
      return (orgData.get('subscription', {}).get('isComped', false) == true) ||
             (orgData.get('dataAccessPermission', {}).get('platformAdminAccess', false) == true);
    }

    // Org coach or platform admin with data access
    function canReadOrgData(orgId) {
      return isOrgCoach(orgId) || (isPlatformAdmin() && hasDataAccess(orgId));
    }

    function canWriteOrgData(orgId) {
      return isOrgCoach(orgId) ||
        (isPlatformAdmin() && hasDataAccess(orgId) && isNotImpersonating());
    }

    // =========================================================
    // ORGANIZATIONS
    // =========================================================

    match /organizations/{orgId} {
      allow read: if isPlatformAdmin() || isOrgCoach(orgId);
      allow write: if isPlatformAdmin() || isOrgAdmin(orgId);

      // Coaches
      match /coaches/{coachId} {
        allow read: if canReadOrgData(orgId);
        allow write: if isOrgAdmin(orgId) ||
          (isPlatformAdmin() && hasDataAccess(orgId) && isNotImpersonating());
        // Allow self-write on invite accept
        allow create: if isAuthenticated() && request.auth.uid == coachId;
      }

      // Clients + all subcollections (current, sessions, roadmap, achievements, drafts)
      match /clients/{clientSlug} {
        allow read: if canReadOrgData(orgId);
        allow write: if canWriteOrgData(orgId);

        // Live composite state — source of truth for current client data
        match /current/{doc} {
          allow read: if canReadOrgData(orgId);
          allow write: if canWriteOrgData(orgId);
        }

        // Assessment event log — append-only, immutable after write
        match /sessions/{sessionId} {
          allow read: if canReadOrgData(orgId);
          // Only allow create (no update/delete — sessions are immutable)
          allow create: if canWriteOrgData(orgId);
          allow update, delete: if isPlatformAdmin();
        }

        // Roadmap — phases and metric thresholds
        match /roadmap/{doc} {
          allow read: if canReadOrgData(orgId);
          allow write: if canWriteOrgData(orgId);
        }

        // Achievements — milestones, status badges, streaks
        match /achievements/{doc} {
          allow read: if canReadOrgData(orgId);
          allow write: if canWriteOrgData(orgId);
        }

        // Assessment drafts — save-for-later
        match /assessmentDrafts/{doc} {
          allow read: if canReadOrgData(orgId);
          allow write: if canWriteOrgData(orgId);
        }
      }

      // GDPR erasure requests
      match /erasureRequests/{requestId} {
        allow read: if isOrgAdmin(orgId) || (isPlatformAdmin() && hasDataAccess(orgId));
        allow create: if true; // Anyone can submit an erasure request
        allow update: if isOrgAdmin(orgId) || (isPlatformAdmin() && hasDataAccess(orgId));
        allow delete: if false;
      }
    }

    // =========================================================
    // USER PROFILES  (one per Firebase Auth user — coaches)
    // =========================================================

    match /userProfiles/{uid} {
      allow read: if request.auth.uid == uid ||
        isPlatformAdmin() ||
        (isAuthenticated() &&
          resource.data.organizationId ==
          get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.organizationId);
      allow write: if request.auth.uid == uid || isPlatformAdmin();
    }

    // =========================================================
    // PUBLIC REPORTS  (client PWA credential)
    // shareToken is both the doc ID and the client's credential.
    // The document holds enough data to render the client's current view.
    // =========================================================

    match /publicReports/{token} {
      allow read: if true; // Token is the credential — anyone with the URL can read
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && resource.data.coachUid == request.auth.uid;
    }

    // =========================================================
    // LIVE SESSIONS  (real-time posture capture)
    // =========================================================

    match /live_sessions/{sessionId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      // Unauthenticated companion (client mobile) may only update capture fields
      allow update: if !isAuthenticated() &&
        exists(/databases/$(database)/documents/live_sessions/$(sessionId)) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'companionJoined', 'lastHeartbeat', 'postureImages',
          'analysis', 'companionLogs',
          'landmarks_front', 'landmarks_back',
          'landmarks_side-left', 'landmarks_side-right'
        ]);
    }

    // =========================================================
    // NOTIFICATIONS  (per-user feed, keyed by Firebase Auth UID)
    // =========================================================

    match /notifications/{uid}/items/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid == uid;
      allow delete: if isAuthenticated() && request.auth.uid == uid;
    }

    // =========================================================
    // PLATFORM ANALYTICS  (Cloud Functions write only)
    // =========================================================

    match /platform_analytics/{doc} {
      allow read: if isPlatformAdmin();
      // Frontend may only clear the "new badge" marker — nothing else
      allow update: if isPlatformAdmin() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenByAdminAt']);
      allow write: if false;
    }

    // =========================================================
    // SYSTEM STATS
    // =========================================================

    match /system_stats/{document} {
      allow read: if isPlatformAdmin();
      allow write: if isPlatformAdmin();
    }

    // =========================================================
    // PLATFORM CONFIG  (feature flags, maintenance mode)
    // Public read so unauthenticated users can see maintenance page.
    // =========================================================

    match /platform/{document} {
      allow read: if true;
      allow write: if isPlatformAdmin();

      match /active_impersonations/sessions/{adminUid} {
        allow read: if isAuthenticated();
        allow write: if isPlatformAdmin() && request.auth.uid == adminUid;
      }
    }

    // =========================================================
    // PLATFORM ADMINS
    // =========================================================

    match /platform_admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if isPlatformAdmin();
    }

    match /platform_admin_lookup/{lookupId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // =========================================================
    // PLATFORM AUDIT LOGS
    // =========================================================

    match /platform_audit_logs/{document=**} {
      allow read: if isPlatformAdmin();
      allow write: if isPlatformAdmin();
    }

    // =========================================================
    // AI USAGE LOGS  (root-level, written by Cloud Functions)
    // Platform admins can read all logs.
    // Org coaches can read logs scoped to their organisation.
    // Writes are Cloud Function only (no client write path).
    // =========================================================

    match /ai_usage_logs/{logId} {
      allow read: if isPlatformAdmin() ||
        (isAuthenticated() &&
          resource.data.organizationId != null &&
          isOrgCoach(resource.data.organizationId));
      allow write: if false;
    }

    // =========================================================
    // RATE LIMIT COUNTERS  (Cloud Functions only)
    // =========================================================

    match /_rateLimits/{key} {
      allow read, write: if false;
    }
  }
}
