# -----------------------------------------------------------------------------
# One Assess — environment template (copy to .env.local / Firebase Functions config)
# -----------------------------------------------------------------------------

# --- Frontend (Vite) ---
# Publishable key only; never put secret keys in VITE_*.
VITE_STRIPE_PUBLISHABLE_KEY=

# Optional: separate test/live publishable keys if you switch at build time
# VITE_STRIPE_PUBLISHABLE_KEY_TEST=pk_test_...
# VITE_STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_...

# App URL for Stripe redirects (also set on Cloud Functions as APP_URL)
# VITE_APP_URL=https://localhost:8080

# --- Firebase Functions: Stripe secrets ---
STRIPE_MODE=test
# Primary secret (or use mode-specific keys below)
STRIPE_SECRET_KEY=
STRIPE_SECRET_KEY_TEST=
STRIPE_SECRET_KEY_LIVE=

STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET_TEST=
STRIPE_WEBHOOK_SECRET_LIVE=

# Success/cancel base URL for Checkout (Functions)
APP_URL=https://one-assess.com

# -----------------------------------------------------------------------------
# Capacity packages (GBP) — Price IDs from Stripe Dashboard or
# `cd functions && STRIPE_SECRET_KEY=sk_test_... npx ts-node --transpile-only src/scripts/createStripeCatalog.ts`
# Replace TEST with LIVE keys when using live mode (STRIPE_MODE=live).
# -----------------------------------------------------------------------------

STRIPE_PACKAGE_A_MONTHLY_TEST=
STRIPE_PACKAGE_A_ANNUAL_TEST=
STRIPE_PACKAGE_B_MONTHLY_TEST=
STRIPE_PACKAGE_B_ANNUAL_TEST=
