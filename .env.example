# -----------------------------------------------------------------------------
# One Assess — environment template (copy to .env.local / Firebase Functions config)
# -----------------------------------------------------------------------------
#
# === STRIPE TEST KEYS — WHERE TO PASTE (from Dashboard → Developers) =========
#
# 1) FRONTEND (repo ROOT, file: .env.local — create it; gitignored)
#    Stripe → Developers → API keys → Publishable key (pk_test_...)
#      VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
#    Optional local redirects for Checkout return URLs:
#      VITE_APP_URL=http://localhost:5173
#
# 2) CLOUD FUNCTIONS (file: functions/.env — create it; gitignored)
#    Copy functions/.env.example → functions/.env then fill in.
#    Stripe → Developers → API keys → Secret key (sk_test_...)
#      STRIPE_MODE=test
#      STRIPE_SECRET_KEY_TEST=sk_test_...
#    (Optional) STRIPE_SECRET_KEY=sk_test_...  — also works; code prefers _TEST when STRIPE_MODE=test
#
# 3) WEBHOOK SIGNING SECRET (same file: functions/.env)
#    Stripe → Developers → Webhooks → your endpoint → Signing secret (whsec_...)
#      STRIPE_WEBHOOK_SECRET_TEST=whsec_...
#
# 4) PRICE IDs (same file: functions/.env) — each Stripe Price → copy price_...
#    Names must match: STRIPE_PACKAGE_S10_MONTHLY_TEST=price_...  (see list below)
#    Custom branding: STRIPE_CUSTOM_BRANDING_TEST=price_...
#
# 5) DEPLOYED FUNCTIONS (production / shared test project)
#    Set the same variables in Google Cloud Console → Cloud Functions → your function
#    → Runtime / environment variables, or use Firebase/Secret Manager. Redeploy after changes.
#
# Webhook URL to register in Stripe (Test mode):
#   https://<region>-<project-id>.cloudfunctions.net/stripeWebhook
#
# ================================================================================

# --- Frontend (Vite) ---
# Publishable key only; never put secret keys in VITE_*.
VITE_STRIPE_PUBLISHABLE_KEY=

# App version — used by Sentry to tag which release an error came from.
# Increment on each deploy (semver). Shown in Sentry → Releases.
VITE_APP_VERSION=1.0.0

# Logged-out landing: “Get started” / “Start gym trial” → real Stripe Checkout (same tier prices as the app).
# Requires functions/.env: ENABLE_LANDING_GUEST_CHECKOUT=true, STRIPE_MODE=test, APP_URL=http://localhost:<vite-port>
# VITE_ENABLE_LANDING_GUEST_CHECKOUT=true

# Optional: separate test/live publishable keys if you switch at build time
# VITE_STRIPE_PUBLISHABLE_KEY_TEST=pk_test_...
# VITE_STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_...

# App URL for Stripe redirects (also set on Cloud Functions as APP_URL)
# VITE_APP_URL=https://localhost:8080

# --- Local Firebase Functions emulator (optional; remote MVP + callables) ---
# VITE_USE_FUNCTIONS_EMULATOR=true
# VITE_FUNCTIONS_EMULATOR_HOST=127.0.0.1
# VITE_FUNCTIONS_EMULATOR_PORT=5001
# Then: cd functions && npm run serve (emulator must match this host/port)

# --- Firebase Functions: Stripe secrets ---
STRIPE_MODE=test
# Primary secret (or use mode-specific keys below)
STRIPE_SECRET_KEY=
STRIPE_SECRET_KEY_TEST=
STRIPE_SECRET_KEY_LIVE=

STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET_TEST=
STRIPE_WEBHOOK_SECRET_LIVE=

# Success/cancel base URL for Checkout (Functions)
APP_URL=https://one-assess.com

# -----------------------------------------------------------------------------
# Capacity packages (GBP) — Price IDs from Stripe Dashboard or
# `cd functions && STRIPE_SECRET_KEY=sk_test_... npx ts-node --transpile-only src/scripts/createStripeCatalog.ts`
# Replace TEST with LIVE keys when using live mode (STRIPE_MODE=live).
# -----------------------------------------------------------------------------

STRIPE_PACKAGE_A_MONTHLY_TEST=
STRIPE_PACKAGE_A_ANNUAL_TEST=
